<Window x:Class="plexrandom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:plexrandom"
        mc:Ignorable="d"
        Title="Plex Randomizer" Height="850" Width="900"
        Icon="pack://application:,,,/Resources/plexrandom.ico"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    <Grid Margin="15">
        <TabControl>
            <!-- Randomize Abteilung -->
            <TabItem Header="Randomize!">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Bibliothek" FontWeight="Bold" Margin="0,0,0,5" Foreground="{StaticResource AccentBrush}" />
                        <ComboBox ItemsSource="{Binding Libraries}" 
                                  SelectedItem="{Binding SelectedLibrary}" 
                                  DisplayMemberPath="Title" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Genre" FontWeight="Bold" Margin="0,0,0,5" Foreground="{StaticResource AccentBrush}" />
                        <ComboBox ItemsSource="{Binding Genres}" 
                                  SelectedItem="{Binding SelectedGenre}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15" Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding OnlyUnseen}" Content="nur ungesehene" VerticalAlignment="Center" />
                        
                        <TextBlock Text="Jahr von:" VerticalAlignment="Center" Margin="20,0,10,0" />
                        <TextBox Text="{Binding YearFrom, UpdateSourceTrigger=PropertyChanged}" Width="50" VerticalAlignment="Center" />
                        
                        <TextBlock Text="bis:" VerticalAlignment="Center" Margin="10,0,10,0" />
                        <TextBox Text="{Binding YearTo, UpdateSourceTrigger=PropertyChanged}" Width="50" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Anzahl Entries in Playlist: " FontWeight="Bold" />
                            <TextBlock Text="{Binding PlaylistEntryCount}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        </StackPanel>
                        <Slider Minimum="{Binding Config.MinEntries}" 
                                Maximum="50" 
                                Value="{Binding PlaylistEntryCount}" 
                                TickFrequency="5" 
                                IsSnapToTickEnabled="True" />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                            <TextBlock Text="Maximale Laufzeit (min): " FontWeight="Bold" />
                            <TextBlock Text="{Binding MaxDuration}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        </StackPanel>
                        <Slider Minimum="60" 
                                Maximum="300" 
                                Value="{Binding MaxDuration}" 
                                TickFrequency="10" 
                                IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <Button Grid.Row="4" Content="Randomize!" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RandomizeCommand}" 
                            Height="40" Margin="0,0,0,15" />

                    <ListView Grid.Row="5" ItemsSource="{Binding PlaylistPreview}" SelectedItem="{Binding SelectedMovie}">
                        <ListView.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding PlayMovieCommand}" 
                                          CommandParameter="{Binding SelectedMovie}" />
                        </ListView.InputBindings>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Platz" DisplayMemberBinding="{Binding PlaylistPosition}" Width="45" />
                                <GridViewColumn Header="Titel" DisplayMemberBinding="{Binding Title}" Width="300" />
                                <GridViewColumn Header="Jahr" DisplayMemberBinding="{Binding Year}" Width="55" />
                                <GridViewColumn Header="Laufzeit" DisplayMemberBinding="{Binding DurationDisplay}" Width="80" />
                                <GridViewColumn Header="Genres" DisplayMemberBinding="{Binding GenresDisplay}" Width="250" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <UniformGrid Grid.Row="6" Columns="2" Margin="0,15,0,0">
                        <Button Content="Send to Plex" 
                                Command="{Binding SendCommand}" 
                                Height="40" Margin="0,0,5,0" />
                        <Button Content="Open entry in Plex client" 
                                Command="{Binding PlayMovieCommand}"
                                CommandParameter="{Binding SelectedMovie}"
                                Height="40" Margin="5,0,0,0" />
                    </UniformGrid>
                </Grid>
            </TabItem>
            
            <!-- Recent Playlists Abteilung -->
            <TabItem Header="Recent Playlists">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ListView Grid.Row="0" ItemsSource="{Binding RecentPlaylists}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Titel" DisplayMemberBinding="{Binding Title}" Width="400" />
                                <GridViewColumn Header="Erstellt am" DisplayMemberBinding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150" />
                                <GridViewColumn Header="Aktionen" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑" 
                                                    Command="{Binding DataContext.DeletePlaylistCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Playlist in Plex löschen"
                                                    Background="Transparent" BorderBrush="Transparent" Foreground="Red" 
                                                    FontSize="16" Cursor="Hand" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Config Abteilung -->
            <TabItem Header="Config">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Server -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,15" />
                    <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Config.Url, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="Port:" VerticalAlignment="Center" Margin="5,0,10,0" />
                        <TextBox Grid.Column="2" Text="{Binding Config.Port, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <!-- Plextoken -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Plextoken:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,15" />
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Input controls -->
                        <Grid Grid.Column="0">
                            <TextBox x:Name="TokenTextBox" Text="{Binding PlexToken, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTokenVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <PasswordBox x:Name="TokenPasswordBox" PasswordChanged="TokenPasswordBox_PasswordChanged">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTokenVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>
                        </Grid>

                        <!-- Toggle Button -->
                        <Button Grid.Column="1" 
                                Command="{Binding ToggleTokenVisibilityCommand}"
                                Content="👁" 
                                FontSize="16"
                                Width="40" Height="Auto" 
                                Margin="10,0,0,0"
                                Padding="0"
                                ToolTip="Token anzeigen/verstecken" />
                    </Grid>

                    <!-- Check Connection -->
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,25">
                        <Button Content="Check Connection" Command="{Binding CheckConnectionCommand}" Width="160" Height="30" />
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="{Binding ConnectionStatusColor}" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" />
                    </StackPanel>

                    <!-- Minimum Entries -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Minimum Entries Playlist:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,15" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Config.MinEntries, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="0,0,0,15" />

                    <!-- Default Movie Duration -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Standard Filmlänge (min):" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,15" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Config.DefaultMovieDuration, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="0,0,0,15" />

                    <!-- Load Libraries -->
                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,15,0,0">
                        <Button Content="{Binding RefreshButtonText}" Command="{Binding RefreshLibrariesCommand}" Height="35" Padding="20,5" />
                        <TextBlock Text="{Binding LibraryStatus}" Foreground="{Binding LibraryStatusColor}" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
